{
  "name": "user-management",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "nodemon src/app.ts",
    "migrate": "npx sequelize-cli db:migrate --config config/config.js",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --config config/config.js",
    "seed": "npx sequelize-cli db:seed:all --config config/config.js",
    "seed:undo": "npx sequelize-cli db:seed:undo --config config/config.js",
    "clean": "rm -rf dist",
    "test": "npx jest --coverage --passWithNoTests",
    "test:watch": "npx jest --watch",
    "test:unit": "npx jest --testPathPattern=unit --passWithNoTests",
    "test:integration": "npx jest --testPathPattern=integration --passWithNoTests",
    "test:coverage": "npx jest --coverage --coverageDirectory=coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.20.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-jest": "^30.3.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
